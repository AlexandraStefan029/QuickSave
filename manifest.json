{
  "manifest_version": 3,
  "name": "Context Saver",
  "version": "1.0",
  "description": "Save selected text with context.",
  "action": {
    "default_popup": "popup.html"
  },
  "permissions": ["storage", "activeTab", "contextMenus", "windows"],
  "background": {
    "service_worker": "background.js"
  }
}